# ─────────────────────────────────────────
# Terraform sensitive files
# ─────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfvars
terraform/*.tfvars.json

# SSH Private Key — never commit this
terraform/*.pem
*.pem

# ─────────────────────────────────────────
# Environment variables & secrets
# ─────────────────────────────────────────
.env
.env.*
*.env
secrets.yml
secrets.yaml
secrets.json

# ─────────────────────────────────────────
# AWS credentials
# ─────────────────────────────────────────
.aws/
credentials
aws_credentials

